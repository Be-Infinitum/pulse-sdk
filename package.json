{
  "name": "@beinfi/pulse-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Pulse Payment Platform API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./ai": {
      "import": {
        "types": "./dist/ai.d.mts",
        "default": "./dist/ai.mjs"
      },
      "require": {
        "types": "./dist/ai.d.ts",
        "default": "./dist/ai.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pulse",
    "payments",
    "crypto",
    "stablecoin",
    "usdc",
    "usdt",
    "pix",
    "sdk",
    "api",
    "fintech",
    "brazil"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Be-Infinitum/pulse-sdk.git"
  },
  "homepage": "https://github.com/Be-Infinitum/pulse-sdk#readme",
  "bugs": {
    "url": "https://github.com/Be-Infinitum/pulse-sdk/issues"
  },
  "devDependencies": {
    "@ai-sdk/google": "^3.0.29",
    "@ai-sdk/openai": "^3.0.29",
    "@ngrok/ngrok": "^1.4.1",
    "@types/node": "^25.2.3",
    "ai": "^6.0.86",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=1.0.0",
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/provider": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
